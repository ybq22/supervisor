# LLM API Configuration Example
# Copy this file to .env and fill in your API keys
#
# This file is automatically loaded by the deep analysis system

# ============================================================================
# Choose Your API Provider
# ============================================================================
# Options: anthropic (default) | openai
LLM_API=anthropic

# ============================================================================
# Anthropic Claude Configuration
# ============================================================================
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: specify model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-opus-4-20250514
# ANTHROPIC_MODEL=claude-haiku-4-20250514

# Optional: use custom base URL (for Anthropic-compatible APIs)
# Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================================================
# OpenAI Configuration
# ============================================================================
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional: specify model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4-turbo
# OPENAI_MODEL=gpt-3.5-turbo

# Optional: use custom base URL (for OpenAI-compatible APIs)
# Default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# OpenAI-Compatible API Examples
# ============================================================================
# You can use any OpenAI-compatible API by setting OPENAI_BASE_URL

# Azure OpenAI
# LLM_API=openai
# OPENAI_API_KEY=your-azure-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL=gpt-4

# DeepSeek
# LLM_API=openai
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Groq
# LLM_API=openai
# OPENAI_API_KEY=your-groq-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Anthropic-Compatible APIs
# LLM_API=anthropic
# ANTHROPIC_API_KEY=your-key
# ANTHROPIC_BASE_URL=https://your-custom-anthropic-api.com

# ============================================================================
# Notes
# ============================================================================
# 1. This file is automatically loaded - no need to manually source it
# 2. Only configure ONE provider (either Anthropic or OpenAI)
# 3. If LLM_API=openai, make sure OPENAI_API_KEY is set
# 4. If LLM_API=anthropic or not set, make sure ANTHROPIC_API_KEY is set
# 5. Never commit this file with real API keys to git
# 6. Keep this file in the project root directory
